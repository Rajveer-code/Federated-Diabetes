# OS
.DS_Store
Thumbs.db
desktop.ini

# Large data files — too big for GitHub, available from CDC
data/*.csv
data/*.parquet
data/*.feather

# Model weights and artefacts — reproducible from code
models/*.pt
models/*.pkl
models/*.npy
artefacts/*.joblib
artefacts/*.pkl

# Results — regenerated by running the pipeline
results/*.json
results/*.csv
results/*.tex
results/*.npy

# Plots — regenerated by running the pipeline
plots/*.png
plots/*.pdf
plots/*.svg

# Manuscript docx (large binary, managed separately)
*.docx

# Misc
*.log
*.tmp
